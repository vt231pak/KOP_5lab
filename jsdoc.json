{
  "source": {
    "include": ["src"],
    "includePattern": ".*\\.tsx?$",
    "excludePattern": "(^|\\/|\\\\)node_modules(\\$|/|\\\\)"
  },
  "opts": {
    "destination": "./docs",
    "recurse": true,
    "readme": "./README.md"
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  },
  "plugins": [
    "plugins/markdown"
  ]
}
